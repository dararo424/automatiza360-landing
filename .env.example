# Copia este archivo a .env.local (desarrollo) o configura como env vars en Vercel (producción)
# DEV: pnpm dev usa .env.local automáticamente
# PROD: en Vercel, configura estas variables en Project Settings → Environment Variables

# URL de la app SaaS (a donde redirige el botón "Empezar")
# Local: http://localhost:5173
# Producción: https://app.automatiza360.com
VITE_APP_URL=http://localhost:5173

# URL del backend API (usado por BusinessAnalyzer.tsx para análisis con IA y auto-onboard)
# Local: http://localhost:3000
# Producción: https://api.automatiza360.com
VITE_API_URL=http://localhost:3000

# Meta Pixel ID (Facebook Pixel para tracking de conversiones)
# Obtener en: https://business.facebook.com → Events Manager → tu Pixel → Settings
# Sin este valor el tracking NO funciona y no medirás conversiones de Ads.
VITE_META_PIXEL_ID=
